[
{ "key": "ctrl+0",                "command": "workbench.action.focusSideBar" },
{ "key": "ctrl+1",                "command": "workbench.action.focusFirstEditorGroup" },
{ "key": "ctrl+2",                "command": "workbench.action.focusSecondEditorGroup" },
{ "key": "ctrl+3",                "command": "workbench.action.focusThirdEditorGroup" },
{ "key": "ctrl+4",                "command": "workbench.action.focusFourthEditorGroup" },
{ "key": "ctrl+5",                "command": "workbench.action.focusFifthEditorGroup" },
{ "key": "ctrl+7",                "command": "workbench.action.focusSeventhEditorGroup" },
{ "key": "ctrl+8",                "command": "workbench.action.focusEighthEditorGroup" },

{ "key": "ctrl+t",                "command": "workbench.action.focusPanel" },
{ "key": "ctrl+x t",              "command": "workbench.action.toggleMaximizedPanel" },
{ "key": "ctrl+x j",              "command": "workbench.action.togglePanel" },

{ "key": "ctrl+=",                "command": "editor.action.smartSelect.expand",
                                     "when": "editorTextFocus" },
{ "key": "ctrl+-",                "command": "editor.action.smartSelect.shrink",
                                     "when": "editorTextFocus" },
{ "key": "ctrl+x left",           "command": "workbench.action.navigateBack" }, // Rebind so it doesn't conflict with undo_expand_region

{ "key": "ctrl-enter",            "command": "editor.toggleFold",
                                     "when": "editorTextFocus && foldingEnabled" },

// magit
{ "key": "ctrl+m s",               "command": "magit.status" },
{ "key": "ctrl+m b",               "command": "magit.blame-file" },
{ "key": "ctrl+m d",               "command": "magit.diff-file" },
]
